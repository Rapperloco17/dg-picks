generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id          String   @id @default(uuid())
  fixtureId   Int      @unique
  leagueId    Int
  leagueName  String
  season      Int
  round       String?
  date        DateTime
  timestamp   Int
  timezone    String
  status      String
  
  homeTeamId   Int
  homeTeamName String
  awayTeamId   Int
  awayTeamName String
  
  homeGoals    Int?
  awayGoals    Int?
  homeScoreHT  Int?
  awayScoreHT  Int?
  homeScoreFT  Int?
  awayScoreFT  Int?
  homeScoreET  Int?
  awayScoreET  Int?
  homeScoreP   Int?
  awayScoreP   Int?
  
  // Estadísticas enriquecidas
  homeCorners  Int?     @default(0)
  awayCorners  Int?     @default(0)
  homeYellowCards Int?  @default(0)
  awayYellowCards Int?  @default(0)
  homeRedCards    Int?  @default(0)
  awayRedCards    Int?  @default(0)
  homePossession  Float? @default(50)
  awayPossession  Float? @default(50)
  homeShots       Int?   @default(0)
  awayShots       Int?   @default(0)
  homeShotsOnTarget Int? @default(0)
  awayShotsOnTarget Int? @default(0)
  
  // Raw data completo
  rawData     Json
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([leagueId])
  @@index([date])
  @@index([status])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

// NUEVO: Ligas
model League {
  id          Int       @id @unique
  name        String
  country     String
  countryCode String?
  logo        String?
  flag        String?
  season      Int
  seasonStart DateTime?
  seasonEnd   DateTime?
  type        String?   // league, cup, etc
  tier        Int       @default(3) // 1 = Top tier, 2 = Second tier, 3 = Lower tiers
  standings   Standing[]
  updatedAt   DateTime  @updatedAt
  
  @@index([country])
  @@index([season])
  @@index([tier])
}

// NUEVO: Equipos con estadísticas detalladas
model Team {
  id          Int       @id @unique
  name        String
  code        String?
  country     String?
  founded     Int?
  logo        String?
  venueName   String?
  venueCity   String?
  
  // Forma reciente (últimos 5 partidos)
  form        String?   // Ej: "WWDLL"
  
  // Estadísticas de la temporada
  played      Int       @default(0)
  won         Int       @default(0)
  drawn       Int       @default(0)
  lost        Int       @default(0)
  goalsFor    Int       @default(0)
  goalsAgainst Int      @default(0)
  points      Int       @default(0)
  
  // Estadísticas avanzadas
  avgPossession     Float?  @default(50)
  avgCornersFor     Float?  @default(0)
  avgCornersAgainst Float?  @default(0)
  avgYellowCards    Float?  @default(0)
  avgShots          Float?  @default(0)
  avgShotsOnTarget  Float?  @default(0)
  
  standings Standing[]
  updatedAt DateTime @updatedAt
  
  @@index([name])
  @@index([country])
}

// NUEVO: Tabla de posiciones
model Standing {
  id           String   @id @default(uuid())
  league       League   @relation(fields: [leagueId], references: [id])
  leagueId     Int
  team         Team     @relation(fields: [teamId], references: [id])
  teamId       Int
  season       Int
  
  // Posición
  rank         Int
  
  // Estadísticas
  played       Int      @default(0)
  won          Int      @default(0)
  drawn        Int      @default(0)
  lost         Int      @default(0)
  goalsFor     Int      @default(0)
  goalsAgainst Int      @default(0)
  goalDiff     Int      @default(0)
  points       Int      @default(0)
  
  // Forma
  form         String?  // "WWDLL"
  
  // Description (para clasificación a torneos)
  description  String?
  
  updatedAt    DateTime @updatedAt
  
  @@unique([leagueId, teamId, season])
  @@index([leagueId, season])
  @@index([rank])
}

// NUEVO: Partidos en vivo
model LiveMatch {
  id              String   @id @default(uuid())
  fixtureId       Int      @unique
  leagueId        Int
  leagueName      String
  
  homeTeamId      Int
  homeTeamName    String
  awayTeamId      Int
  awayTeamName    String
  
  // Marcador
  homeGoals       Int      @default(0)
  awayGoals       Int      @default(0)
  
  // Tiempo
  elapsed         Int      @default(0)  // Minutos
  status          String   // LIVE, HT, FT, etc
  
  // Estadísticas en vivo
  homePossession  Int?     @default(50)
  awayPossession  Int?     @default(50)
  homeShots       Int?     @default(0)
  awayShots       Int?     @default(0)
  homeShotsOnTarget Int?   @default(0)
  awayShotsOnTarget Int?   @default(0)
  homeCorners     Int?     @default(0)
  awayCorners     Int?     @default(0)
  homeYellowCards Int?     @default(0)
  awayYellowCards Int?     @default(0)
  homeRedCards    Int?     @default(0)
  awayRedCards    Int?     @default(0)
  
  // Momios (odds) en vivo
  homeOdds        Float?
  drawOdds        Float?
  awayOdds        Float?
  over25Odds      Float?
  under25Odds     Float?
  bttsYesOdds     Float?
  bttsNoOdds      Float?
  
  // Predicción ML
  mlPrediction    Json?    // {homeWin: 0.45, draw: 0.30, awayWin: 0.25, suggestedBet: "over2.5"}
  
  // Última actualización
  lastUpdated     DateTime @updatedAt
  createdAt       DateTime @default(now())
  
  @@index([leagueId])
  @@index([status])
  @@index([lastUpdated])
}

model ModelStats {
  id            String   @id @default(uuid())
  version       String   @unique
  trainedAt     DateTime @default(now())
  matchesCount  Int
  accuracy      Float
  rmse          Float
  features      Json
  weights       Json
  
  @@index([trainedAt])
}

model SyncLog {
  id          String   @id @default(uuid())
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  status      String   // running, completed, error
  newMatches  Int      @default(0)
  errors      String?
  
  @@index([startedAt])
}
